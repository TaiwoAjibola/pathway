generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  applications   Application[]
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pathway {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  country         String
  visaCategory    String
  version         String   @default("1.0.0")
  active          Boolean  @default(true)
  config          Json
  stages          Stage[]
  applications    Application[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Stage {
  id          String   @id @default(cuid())
  pathwayId   String
  code        String
  name        String
  description String?
  order       Int
  autoUnlock  Boolean  @default(false)
  estimatedDurationDays Int?
  config      Json?
  pathway     Pathway  @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  tasks       TaskTemplate[]
  applications ApplicationStage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pathwayId, code])
}

model TaskTemplate {
  id                   String   @id @default(cuid())
  stageId              String
  code                 String
  title                String
  description          String?
  reason               String?
  priority             Priority @default(MEDIUM)
  difficulty           Difficulty @default(MODERATE)
  estimatedTimeMinutes Int      @default(30)
  autoUnlock           Boolean  @default(true)
  autoComplete         Boolean  @default(false)
  completionCriteria   Json?
  helpfulResources     Json?
  stage                Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  instances            TaskInstance[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([stageId, code])
}

model Application {
  id                 String   @id @default(cuid())
  userId             String
  pathwayId          String
  label              String
  status             ApplicationStatus @default(PLANNING)
  currentStageId     String?
  crsScore           Int      @default(0)
  targetCrsScore     Int      @default(500)
  estimatedCompletionDate DateTime?
  metadata           Json?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathway            Pathway  @relation(fields: [pathwayId], references: [id])
  applicants         Applicant[]
  stageProgress      ApplicationStage[]
  taskInstances      TaskInstance[]
  crsSnapshots       CRSSnapshot[]
  familyMembers      FamilyMember[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Applicant {
  id                 String   @id @default(cuid())
  applicationId      String
  type               ApplicantType @default(PRIMARY)
  isDependent        Boolean  @default(false)
  firstName          String
  lastName           String
  dateOfBirth        DateTime?
  nationality        String?
  countryOfResidence String?
  maritalStatus      MaritalStatus @default(SINGLE)
  email              String?
  phone              String?
  metadata           Json?
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  educationEntries   Education[]
  employmentEntries  Employment[]
  languageTests      LanguageTest[]
  documents          Document[]
  immigrationHistory ImmigrationRecord[]
  credentialAssessments CredentialAssessment[]
  medicalStatus      MedicalStatus @default(NOT_STARTED)
  policeCertificates PoliceCertificate[]
  proofOfFunds       ProofOfFunds?
  taskAssignees      TaskAssignee[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model ApplicationStage {
  id            String      @id @default(cuid())
  applicationId String
  stageId       String
  status        StageStatus @default(LOCKED)
  progress      Float       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage         Stage       @relation(fields: [stageId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([applicationId, stageId])
}

model TaskInstance {
  id                 String       @id @default(cuid())
  applicationId      String
  templateId         String?
  stageId            String
  title              String
  description        String?
  taskType           TaskType
  category           String?
  priority           Priority     @default(MEDIUM)
  dueDate            DateTime?
  completedDate      DateTime?
  status             TaskStatus   @default(NOT_STARTED)
  progress           Int          @default(0)
  notes              String?
  evidence           String?
  estimatedCost      Float?
  actualCost         Float?
  currency           String       @default("CAD")
  paid               Boolean      @default(false)
  outstanding        Float?
  paymentDate        DateTime?
  receiptUrl         String?
  metadata           Json?
  application        Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  template           TaskTemplate? @relation(fields: [templateId], references: [id])
  assignees          TaskAssignee[]
  documents          Document[]
  dependencies       TaskDependency[] @relation("TaskDependencies")
  dependedBy         TaskDependency[] @relation("TaskDependedBy")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model TaskAssignee {
  id          String       @id @default(cuid())
  taskId      String
  applicantId String
  task        TaskInstance @relation(fields: [taskId], references: [id], onDelete: Cascade)
  applicant   Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([taskId, applicantId])
}

model TaskDependency {
  id          String       @id @default(cuid())
  taskId      String
  dependsOnId String
  task        TaskInstance @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn   TaskInstance @relation("TaskDependedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([taskId, dependsOnId])
}

model Document {
  id               String          @id @default(cuid())
  applicantId      String
  taskId           String?
  name             String
  description      String?
  issuingAuthority String?
  collected        Boolean         @default(false)
  uploaded         Boolean         @default(false)
  verified         Boolean         @default(false)
  expiryDate       DateTime?
  notes            String?
  applicant        Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  task             TaskInstance?   @relation(fields: [taskId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Education {
  id              String   @id @default(cuid())
  applicantId     String
  level           EducationLevel
  field           String?
  institution     String?
  country         String?
  startDate       DateTime?
  endDate         DateTime?
  earnedDate      DateTime?
  status          String?
  applicant       Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Employment {
  id              String   @id @default(cuid())
  applicantId     String
  company         String
  title           String
  country         String?
  startDate       DateTime?
  endDate         DateTime?
  isCurrent       Boolean  @default(false)
  hoursPerWeek    Int?
  durationYears   Float?
  nocCode         String?
  isSkilled       Boolean  @default(false)
  applicant       Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LanguageTest {
  id                String          @id @default(cuid())
  applicantId       String
  testType          TestType
  language          String
  bookingStatus     BookingStatus   @default(NOT_BOOKED)
  testCenter        String?
  testDate          DateTime?
  bookingReference  String?
  resultStatus      ResultStatus    @default(PENDING)
  listeningScore    Float?
  readingScore      Float?
  writingScore      Float?
  speakingScore     Float?
  overallScore      Float?
  clbListening      Int?
  clbReading        Int?
  clbWriting        Int?
  clbSpeaking       Int?
  nclcLevel         Int?
  testReportUrl     String?
  expiryDate        DateTime?
  studyStreak       Int             @default(0)
  lastStudyDate     DateTime?
  preparationStatus PreparationStatus @default(NOT_STARTED)
  applicant         Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ImmigrationRecord {
  id            String   @id @default(cuid())
  applicantId   String
  country       String
  visaType      String?
  entryDate     DateTime?
  exitDate      DateTime?
  status        String?
  applicant     Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CredentialAssessment {
  id            String   @id @default(cuid())
  applicantId   String
  organization  String
  status        String   @default("NOT_STARTED")
  submittedDate DateTime?
  receivedDate  DateTime?
  equivalency   String?
  reportUrl     String?
  applicant     Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PoliceCertificate {
  id              String   @id @default(cuid())
  applicantId     String
  country         String
  status          String   @default("NOT_STARTED")
  appliedDate     DateTime?
  receivedDate    DateTime?
  expiryDate      DateTime?
  documentUrl     String?
  applicant       Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProofOfFunds {
  id              String   @id @default(cuid())
  applicantId     String   @unique
  currency        String   @default("CAD")
  amount          Float?
  lastUpdated     DateTime?
  documents       Json?
  applicant       Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CRSSnapshot {
  id            String   @id @default(cuid())
  applicationId String
  totalScore    Int
  ageScore      Int      @default(0)
  educationScore Int     @default(0)
  languageScore Int      @default(0)
  secondLanguageScore Int @default(0)
  workExperienceScore Int @default(0)
  skillsTransferScore Int @default(0)
  additionalScore     Int @default(0)
  breakdown     Json?
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}



enum TaskType {
  DOCUMENT
  EXAM
  PAYMENT
  APPLICATION
  APPOINTMENT
  STUDY
  TRAVEL
  MEDICAL
  POLICE_CERTIFICATE
  CREDENTIAL_ASSESSMENT
  LANGUAGE_TEST
  OTHER
}

model FamilyMember {
  id            String      @id @default(cuid())
  applicationId String
  name          String
  role          MemberRole  @default(VIEWER)
  email         String?
  inviteCode    String?     @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum MemberRole {
  VIEWER
  EDITOR
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Difficulty {
  EASY
  MODERATE
  HARD
  COMPLEX
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  BLOCKED
  COMPLETED
  EXPIRED
  NEEDS_REVIEW
}

enum ApplicationStatus {
  PLANNING
  ELIGIBILITY
  DOCUMENTS
  IN_PROGRESS
  SUBMITTED
  APPROVED
  LANDED
}

enum ApplicantType {
  PRIMARY
  SPOUSE
  CHILD
}

enum MaritalStatus {
  SINGLE
  MARRIED
  COMMON_LAW
  DIVORCED
  WIDOWED
  SEPARATED
}

enum StageStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

enum DocumentStatus {
  NOT_UPLOADED
  UPLOADED
  REVIEWING
  APPROVED
  REJECTED
  EXPIRING_SOON
  EXPIRED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_UPDATE
}

enum TestType {
  IELTS_GENERAL
  CELPIP
  TEF
  TCF
}

enum BookingStatus {
  NOT_BOOKED
  BOOKED
  RESCHEDULED
  CANCELLED
}

enum ResultStatus {
  PENDING
  RECEIVED
  VALIDATED
  EXPIRED
}

enum PreparationStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  TAKEN
}

enum MedicalStatus {
  NOT_STARTED
  SCHEDULED
  COMPLETED
  PASSED
  FAILED
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
}


